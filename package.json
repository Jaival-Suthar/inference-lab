{
  "name": "inference-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "node --experimental-strip-types apps/cli/src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{json,md,yml,yaml}": "prettier --write",
    "**/*.{js,mjs,cjs,ts,mts,cts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "debug": "4.4.3",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "ms": "2.1.3",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  }
}
